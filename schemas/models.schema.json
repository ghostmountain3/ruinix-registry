{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ruinix Model Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "models"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string"
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "source",
        "format",
        "backend",
        "family",
        "recommended_tier",
        "context_window",
        "max_output_tokens",
        "default_preset"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "format": {
          "enum": ["mlx", "gguf", "safetensors"]
        },
        "backend": {
          "enum": ["mlx", "llamacpp"]
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "architecture": {
          "type": "string"
        },
        "quantization": {
          "type": "string"
        },
        "recommended_tier": {
          "enum": ["compact", "balanced", "large", "workstation"]
        },
        "context_window": {
          "type": "integer",
          "minimum": 1
        },
        "max_output_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "default_preset": {
          "enum": ["fast_greedy", "code_precise", "code_balanced", "json_strict", "creative"]
        },
        "tokenizer_path_expectation": {
          "type": "string"
        },
        "chat_template": {
          "enum": ["qwen_chatml", "deepseek_qwen3"]
        },
        "stop_strings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compatibility": {
          "enum": ["supported", "experimental", "unsupported"]
        },
        "role": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "repo"],
      "properties": {
        "type": {
          "enum": ["huggingface"]
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        }
      }
    }
  }
}
